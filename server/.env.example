# Server port
PORT=4000

# MongoDB Atlas — prefer standard URI on Windows if mongodb+srv gives querySrv ECONNREFUSED
# Atlas → Connect → Drivers → "standard connection string" (not SRV)
MONGODB_URI=mongodb://YOUR_USER:YOUR_PASSWORD@shard-00-00.xxxxx.mongodb.net:27017,shard-00-01.xxxxx.mongodb.net:27017,shard-00-02.xxxxx.mongodb.net:27017/mindcare?ssl=true&authSource=admin&replicaSet=atlas-xxxxx-shard-0&retryWrites=true&w=majority

# Optional SRV form (works on many Mac/Linux setups)
# MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/mindcare?retryWrites=true&w=majority

# JWT secret (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google Gemini API — https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=Your_Gemini_API_Key_Here
# Use gemini-2.5-flash if gemini-2.0-flash hits quota (429)
GEMINI_MODEL=gemini-2.5-flash

# Allowed frontend origin (Vite dev server)
CLIENT_URL=http://localhost:5173
