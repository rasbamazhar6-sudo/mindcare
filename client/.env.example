# ─── Local development ─────────────────────────────────────────────
# Use /api so Vite proxies to the Express server (see vite.config.js)
VITE_API_URL=/api

# Optional request timeout in milliseconds
# VITE_API_TIMEOUT=45000

# ─── Production (Vercel / static host) ─────────────────────────────
# Set this in your hosting dashboard (Environment Variables).
# Must be your deployed backend URL including the /api path.
#
# Example:
# VITE_API_URL=https://mindcare-api.onrender.com/api
